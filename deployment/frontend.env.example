# Frontend Production Configuration

# Point this to the public URL of your deployed FastAPI Backend
API_HOST=https://your-backend-api.onrender.com

# Streamlit Configuration
STREAMLIT_SERVER_ENABLE_CORS=true
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_PORT=8501

# UI Toggles
ENABLE_EVALUATION_TAB=false # Usually disable evaluation execution in public production
SHOW_TRACE_LOGS=true
