# Backend Production Configuration

# Environment Profile
ENVIRONMENT=production
DEBUG=False

# CORS Settings (Allow UI to connect to Backend)
CORS_ORIGINS=https://your-ui-app.streamlit.app,http://localhost:8501

# Infrastructure Connection URLs
# In production, these should point to managed services (e.g. Elastic Cloud, Qdrant Cloud)
ELASTICSEARCH_URL=https://your-elasticsearch-cluster.es.us-central1.gcp.cloud.es.io
QDRANT_URL=https://your-qdrant-cluster.cloud.qdrant.io

# Index Definitions
ELASTICSEARCH_INDEX=legal_corpus_v1
QDRANT_COLLECTION=legal_vectors_v1

# Retrieval Backend
# Set to 'true' for local testing (uses in-memory mocks)
# Set to 'false' for production (connects to real databases above)
HYBRID_USE_MOCK=false

# Model Selection
EMBEDDING_MODEL=legal-bert-base-uncased
LLM_PROVIDER=openai # Set to openai, gemini, or anthropic for production

# API Keys (Required in Production)
OPENAI_API_KEY=your_production_openai_api_key_here
ANTHROPIC_API_KEY=your_production_anthropic_api_key_here
GEMINI_API_KEY=your_production_gemini_api_key_here

# Security
API_SECRET_KEY=generate_a_long_random_string_here
